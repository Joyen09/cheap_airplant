# ── Telegram ───────────────────────────────────────────────────────────────
# 跟 @BotFather 申請一個 bot，把它給你的 token 貼在這裡
TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token

# ── Amadeus Self-Service API ────────────────────────────────────────────────
# 到 https://developers.amadeus.com 註冊，建立一個 App 後取得 Key / Secret
AMADEUS_CLIENT_ID=your-amadeus-api-key
AMADEUS_CLIENT_SECRET=your-amadeus-api-secret
# test = 免費沙盒環境（資料較少）; production = 正式環境
AMADEUS_ENV=test

# ── 行為設定 ─────────────────────────────────────────────────────────────────
# 每隔幾分鐘檢查一次所有監控的機票價格
CHECK_INTERVAL_MINUTES=60
# 報價幣別
CURRENCY=TWD
# 大人人數
ADULTS=1
# 即使沒設預算，價格比歷史最低再便宜這個比例(0.05 = 5%)就主動通知
NEW_LOW_NOTIFY_RATIO=0.05
# 資料庫檔案位置
DB_PATH=data/watches.db
