# ── 對話平台（Telegram 或 Discord 擇一即可）─────────────────────────────────
# Telegram：跟 @BotFather 申請 bot 拿 token（跑 main.py）
TELEGRAM_BOT_TOKEN=
# Discord：到 https://discord.com/developers 建 App→Bot 拿 token（跑 main_discord.py）
# 記得在 Bot 設定頁把「MESSAGE CONTENT INTENT」打開
DISCORD_BOT_TOKEN=

# ── 機票資料來源（至少設定一個；兩個都設會自動 fallback）─────────────────────
# Travelpayouts（Aviasales）：免費、不按 API 次數計費，適合高頻監控。
#   到 https://www.travelpayouts.com 免費註冊 → 取得 API token。
#   價格為快取（非即時），且不含中轉機場（via 為盡力而為）。
TRAVELPAYOUTS_TOKEN=your-travelpayouts-token

# SerpApi（Google Flights）：價格最準、即時、含完整中轉機場（via 精準）。
#   到 https://serpapi.com 註冊 → 取得 API key。免費額度約 100 次/月。
#   兩個都設時：平常走 SerpApi，額度用盡會自動退回 Travelpayouts。
SERPAPI_KEY=

# ── 行為設定 ─────────────────────────────────────────────────────────────────
# 每隔幾分鐘檢查一次所有監控的機票價格（僅本機模式 B 用；GitHub Actions 看 cron）
CHECK_INTERVAL_MINUTES=60
# 報價幣別
CURRENCY=TWD
# 大人人數
ADULTS=1
# 「好價」門檻：低於這條航線常態價多少比例就標記好價並通知(0.15 = 便宜 15%)
GOOD_DEAL_RATIO=0.15
# 累積幾筆觀測後才啟用「常態價」判斷（5 分鐘一次的話，10 筆約 50 分鐘）
BASELINE_MIN_SAMPLES=10
# 每天幾點（台北時間 0-23）送一次摘要
DIGEST_HOUR=9
# 資料庫檔案位置（本機模式 B 用）
DB_PATH=data/watches.db
