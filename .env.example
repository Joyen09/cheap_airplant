# ── 對話平台（Telegram 或 Discord 擇一即可）─────────────────────────────────
# Telegram：跟 @BotFather 申請 bot 拿 token（跑 main.py）
TELEGRAM_BOT_TOKEN=
# Discord：到 https://discord.com/developers 建 App→Bot 拿 token（跑 main_discord.py）
# 記得在 Bot 設定頁把「MESSAGE CONTENT INTENT」打開
DISCORD_BOT_TOKEN=

# ── 機票資料來源 ─────────────────────────────────────────────────────────────
# 主力是 Google Flights（fast-flights 套件）：免費、即時、免金鑰、不用設定。
# 下面兩個是「可選備援」，Google 查詢失敗時自動接手（設不設都能跑）：

# Travelpayouts（Aviasales）：免費、不按 API 次數計費（快取價）。
#   到 https://www.travelpayouts.com 免費註冊 → 取得 API token。
TRAVELPAYOUTS_TOKEN=

# SerpApi（Google Flights 官方代理）：免費額度約 100 次/月。
#   到 https://serpapi.com 註冊 → 取得 API key。
SERPAPI_KEY=

# ── 聯盟分潤（可選）────────────────────────────────────────────────────────
# Travelpayouts 後台的 marker（affiliate ID）。設定後，通知裡會多附一條
# 帶分潤的 Aviasales 訂票連結——使用者訂票價格完全不變，Travelpayouts 會
# 付分潤給你。通知文字已註明「此連結含開發者分潤」。
#   到 https://www.travelpayouts.com 註冊 → 加入 Aviasales 計畫 → 取得 marker。
TRAVELPAYOUTS_MARKER=

# ── 行為設定 ─────────────────────────────────────────────────────────────────
# 每隔幾分鐘檢查一次所有監控的機票價格（僅本機模式 B 用；GitHub Actions 看 cron）
CHECK_INTERVAL_MINUTES=60
# 報價幣別
CURRENCY=TWD
# 大人人數
ADULTS=1
# 「好價」門檻：低於這條航線常態價多少比例就標記好價並通知(0.15 = 便宜 15%)
GOOD_DEAL_RATIO=0.15
# 累積幾筆觀測後才啟用「常態價」判斷（5 分鐘一次的話，10 筆約 50 分鐘）
BASELINE_MIN_SAMPLES=10
# 每天幾點（台北時間 0-23）送一次摘要
DIGEST_HOUR=9
# 資料庫檔案位置（本機模式 B 用）
DB_PATH=data/watches.db
